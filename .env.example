# SIGE Condo – Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase

# ID do projeto no Supabase (encontre em: Project Settings > General)
VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"

# Chave pública anon do Supabase (encontre em: Project Settings > API)
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"

# URL do projeto Supabase
VITE_SUPABASE_URL="https://seu-project-id-aqui.supabase.co"

# ── Deploy FTP (Hostinger) ──────────────────────────────────────────────────
# Encontre em: Hostinger → Hosting → FTP Accounts
FTP_HOST="ftp.seu-dominio.com"
FTP_USER="seu-usuario-ftp"
FTP_PASSWORD="sua-senha-ftp"
# Caminho remoto onde os arquivos serão enviados (padrão: /public_html)
FTP_REMOTE_PATH="/public_html"
